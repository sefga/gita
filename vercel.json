{
    "cleanUrls": true,
    "trailingSlash": false,
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=3600"
                }
            ]
        },
        {
            "source": "/content/(.*).json",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=86400"
                },
                {
                    "key": "Content-Type",
                    "value": "application/json; charset=utf-8"
                }
            ]
        }
    ]
}